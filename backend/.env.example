# Bu dosyayi .env olarak kopyalayin ve degerleri doldurun.
#   cp .env.example .env
#
# .env dosyasini asla surum kontrolune eklemeyin.

# Zorunlu. Uretmek icin:  openssl rand -hex 32
JWT_SECRET=

# Zorunlu. Uretmek icin:  openssl rand -base64 24
POSTGRES_PASSWORD=

POSTGRES_USER=vaktinde
POSTGRES_DB=vaktinde

# Erisim tokeni omru (dakika).
ACCESS_TOKEN_MINUTES=30

# Yenileme tokeni omru (gun). Kullanicinin ne siklikta tekrar giris
# yapacagini belirler.
REFRESH_TOKEN_DAYS=180

# Kullanici basina azami fotograf sayisi.
MAX_PHOTOS_PER_USER=500
