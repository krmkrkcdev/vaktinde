# Bu dosyayı ".env" olarak kopyalayın ve kendi bilgilerinizle doldurun.
# .env dosyasını ASLA git'e commit etmeyin (.gitignore'da zaten hariç tutuldu).
#
# Değerlerde boşluk varsa tırnak kullanabilirsiniz: ADI="Bir Değer"

# ---------------- iOS / App Store Connect ----------------
# App Store Connect > Users and Access > Integrations > App Store Connect API
# üzerinden oluşturduğunuz API Key bilgileri:
ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ASC_KEY_FILEPATH=./ios/fastlane/AuthKey_XXXXXXXXXX.p8

# Apple Developer hesabınızdaki Team ID (developer.apple.com/account üzerinde)
APPLE_TEAM_ID=XXXXXXXXXX

# Uygulamanızın bundle identifier'ı (Xcode'daki ile aynı olmalı)
APP_IDENTIFIER=com.sirketiniz.uygulamaadi

# ---------------- iOS / İmzalama (fastlane match) ----------------
# Sertifikaların ŞİFRELİ olarak saklanacağı ÖZEL (private) git deposu.
# Bu depo uygulama kodunuzdan AYRI ve mutlaka private olmalı.
# Örnek: git@github.com:kullaniciadi/ios-certificates.git
# Boş bırakırsanız Xcode'un otomatik imzalaması kullanılır (yalnızca bu Mac'te çalışır).
MATCH_GIT_URL=

# Sertifikaları şifrelemek için kullanılan parola.
# Bunu bir parola yöneticisinde saklayın — kaybederseniz depoyu açamazsınız.
MATCH_PASSWORD=

# ---------------- Android / Google Play ----------------
# Google Play Console > Setup > API access üzerinden oluşturduğunuz
# service account'a ait JSON anahtar dosyasının yolu:
GOOGLE_PLAY_JSON_KEY=./android/fastlane/play-store-credentials.json

# Uygulamanızın package name'i (build.gradle'daki applicationId ile aynı)
ANDROID_PACKAGE_NAME=com.sirketiniz.uygulamaadi

# ---------------- İsteğe bağlı ----------------
# Play Store production kademeli yayın oranı (0.1 = %10). Boş bırakılırsa %100.
# PLAY_ROLLOUT=0.1

# Play Store sürüm notlarının dili (varsayılan: tr-TR)
# PLAY_STORE_LANG=tr-TR
